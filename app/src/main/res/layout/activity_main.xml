                android:textColor="@color/grey"
                android:text="Not scheduled" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/grey"
            android:textSize="12sp"
            android:text="Note: On first run, Android may ask you to allow 'Alarms &amp; reminders' permission. Please allow it so the fake call timer works exactly on time." />

    </LinearLayout>
</ScrollView>
